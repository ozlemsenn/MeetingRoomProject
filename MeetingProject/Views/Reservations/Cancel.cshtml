@model MeetingProject.Models.Reservations
@{
    Layout = null;
}

<div class="container-fluid px-2 py-3 text-center">

    <p class="text-secondary fw-semibold mb-4" style="font-size: 1.05rem;">
        Bu rezervasyonu iptal etmek istediğinize emin misiniz? <br />
        <span class="text-muted small" style="font-weight: normal;">
        Bu işlem geri alınamaz ve toplantı odası başkaları için uygun hale gelir. 
        . </span>
    </p>

    <div class="card border-danger shadow-sm mx-auto mb-4" style="border-radius: 12px; background-color: #fff5f5; max-width: 420px;">
        <div class="card-body p-3">

            <h5 class="fw-bold text-dark mb-2">
                <i class="fas fa-door-open text-danger me-2"></i>
                @ViewBag.OdaAdi
            </h5>

            <hr class="text-danger opacity-25 mx-4 my-2">

            <h6 class="text-muted mb-0 mt-2 d-flex justify-content-center align-items-center gap-3" style="font-size: 0.95rem;">
                <span>
                    <i class="far fa-calendar-alt me-1"></i>
                    @(Model.Date.HasValue ? Model.Date.Value.ToString("dd.MM.yyyy") : "Tarih Belirtilmedi")
                </span>
                <span>
                    <i class="far fa-clock me-1"></i>
                    @(Model.StartTime.HasValue ? Model.StartTime.Value.ToString(@"hh\:mm") : "") - @(Model.EndTime.HasValue ? Model.EndTime.Value.ToString(@"hh\:mm") : "")
                </span>
            </h6>

        </div>
    </div>

    <form id="formIptal" class="px-2 text-start">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />

        <div class="mb-2">
            <label class="form-label text-muted small fw-bold mb-1">İptal Nedeni (İsteğe Bağlı)</label>
            <textarea name="CancelReason" class="form-control shadow-sm border-0 bg-light" style="width: 100% !important; max-width: 100% !important; resize: none;" rows="3" placeholder="Neden iptal ediyorsunuz? (Bu not detaylar ekranında görünecektir)"></textarea>
        </div>
    </form>

</div>

<div class="modal-footer border-0 pt-0 pb-3 justify-content-center">
    <button type="button" class="btn btn-outline-secondary shadow-sm px-4" style="border-radius: 8px;" onclick="$('#islemModali').modal('hide');">Vazgeç</button>
    <button type="button" class="btn btn-danger shadow-sm px-4 fw-bold" style="border-radius: 8px;" onclick="IptalOnayla()">Evet, İptal Et</button>
</div>