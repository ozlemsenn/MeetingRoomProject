@{
    ViewBag.Title = "Rezervasyonlar";
}

<div class="row mb-4" style="margin-top: 20px;">
    <div class="col-md-8">
        <h2 class="text-primary fw-bold">Rezervasyon Yönetimi</h2>
        <p class="text-muted">Toplantı odalarının doluluk durumunu ve rezervasyonları yönetebilirsiniz.</p>
    </div>
    <div class="col-md-4" style="display: flex; justify-content: flex-end; align-items: center;">
        <button class="btn btn-primary" style="border-radius: 20px; font-weight: 600; padding: 10px 20px;" onclick="ModalAc('/Reservations/Create')">
            + Yeni Rezervasyon
        </button>
    </div>
</div>5

    <div class="card shadow-sm" style="border-radius: 15px; border: none;">
        <div class="card-body">
            <table id="rezervasyonTablosu" class="table table-hover table-borderless align-middle">
                <thead class="thead-dark" style="background-color: #343a40; color: white;">
                    <tr>
                        <th class="text-center align-middle" style="width: 10%;">Tarih</th>
                        <th class="text-center align-middle" style="width: 10%;">Saat Aralığı</th>
                        <th class="text-center align-middle" style="width: 20%;">Oda</th>
                        <th class="text-center align-middle" style="width: 20%;">Kullanıcı</th>
                        <th class="text-center align-middle" style="width: 35%;">Açıklama</th>
                        <th class="text-center align-middle" style="width: 10%;">Durum</th>
                        <th class="text-center align-middle" style="width: 20%;">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="rezervasyonListesi">
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="islemModali" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" id="modalIcerik" style="border-radius: 15px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">

            </div>
        </div>
    </div>

    @section scripts {
        <script>
            $(document).ready(function () {
                TabloyuDoldur();
            });

            function TabloyuDoldur() {
                $.ajax({
                    url: '/Reservations/GetReservations',
                    type: 'GET',
                    success: function (data) {
                        if ($.fn.DataTable.isDataTable('#rezervasyonTablosu')) {
                            $('#rezervasyonTablosu').DataTable().destroy();
                        }

                        var html = '';
                        $.each(data, function (i, item) {
                            html += '<tr>';
                            html += '<td class="text-center align-middle"><strong>' + item.Date + '</strong></td>';
                            html += '<td class="text-center align-middle"><span class="badge bg-light text-dark">' + item.StartTime + ' - ' + item.EndTime + '</span></td>';
                            html += '<td class="text-center align-middle">' + item.RoomName + '</td>';
                            html += '<td class="text-center align-middle">' + item.UserName + '</td>';
                            var kisaAciklama = item.Description;
                            if (kisaAciklama && kisaAciklama.length > 30) {
                                kisaAciklama = kisaAciklama.substring(0, 30) + '...'; 
                            }
                            html += '<td>' + kisaAciklama + '</td>';
                            var rozetRengi = 'bg-success'; 
                            if (item.Status === 'Tamamlandı') {
                                rozetRengi = 'bg-secondary'; 
                            } else if (item.Status === 'İptal Edildi') {
                                rozetRengi = 'bg-danger'; 
                            }
                            html += '<td><span class="badge ' + rozetRengi + '">' + item.Status + '</span></td>';

                            html += '<td class="align-middle text-center">';
                            html += '<div class="d-flex justify-content-center align-items-center flex-nowrap gap-1">';

                            html += '<button class="btn btn-sm btn-info text-white shadow-sm" title="Detayları Gör" style="border-radius: 10px; padding: 5px 10px;" onclick="ModalAc(\'/Reservations/Details/' + item.Id + '\')">🔍</button>';

                            if (item.Status !== 'İptal Edildi' && item.Status !== 'Tamamlandı') {
                                
                                html += '<button class="btn btn-sm btn-warning shadow-sm" title="Düzenle" style="border-radius: 10px; padding: 5px 10px;" onclick="ModalAc(\'/Reservations/Edit/' + item.Id + '\')">✏️</button>';

                                html += '<button class="btn btn-sm btn-dark shadow-sm" title="İptal Et" style="border-radius: 10px; padding: 5px 10px;" onclick="ModalAc(\'/Reservations/Cancel/' + item.Id + '\')">🚫</button>';
                            }

                            html += '<button class="btn btn-sm btn-danger shadow-sm" title="Tamamen Sil" style="border-radius: 10px; padding: 5px 10px;" onclick="ModalAc(\'/Reservations/Delete/' + item.Id + '\')">🗑️</button>';

                            html += '</div>';
                            html += '</td>';
                            html += '</tr>';
                        });

                        $('#rezervasyonListesi').html(html);
                        $('#rezervasyonTablosu').DataTable({
                            "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json" }
                        });
                    }
                });
            }

            function ModalAc(url) {
                $.get(url, function (data) {
                    $('#modalIcerik').html(data);
                    $('#islemModali').modal('show');
                });
            }

            function Kaydet() {
                var formData = $('#formRezervasyon').serialize();

                $('#hataMesajiAlani').addClass('d-none');

                $.ajax({
                    url: '/Reservations/Create',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            $('#islemModali').modal('hide');
                            TabloyuDoldur();
                        } else {
                            $('#hataMesajiAlani').removeClass('d-none').html('<strong>⚠️ Uyarı:</strong> ' + response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        $('#hataMesajiAlani').removeClass('d-none').html('<strong>❌ Sunucu Hatası:</strong> İşlem tamamlanamadı.');
                    }
                });
            }

            function Sil() {
                var formData = $('#formSil').serialize();
                $.post('/Reservations/DeleteConfirm', formData, function (response) {
                    if (response.success) {
                        $('#islemModali').modal('hide');
                        TabloyuDoldur();
                    }
                });
            }
            function Guncelle() {
                var formData = $('#formDuzenle').serialize();
                $('#hataMesajiAlaniDuzenle').addClass('d-none');

                $.ajax({
                    url: '/Reservations/Edit',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            $('#islemModali').modal('hide');
                            TabloyuDoldur();
                        } else {
                            $('#hataMesajiAlaniDuzenle').removeClass('d-none').html('<strong>⚠️ Uyarı:</strong> ' + response.message);
                        }
                    },
                    error: function () {
                        $('#hataMesajiAlaniDuzenle').removeClass('d-none').html('<strong>❌ Sunucu Hatası.</strong>');
                    }
                });
            }
            function IptalOnayla() {
                var formData = $('#formIptal').serialize();

                $.post('/Reservations/CancelConfirm', formData, function (response) {
                    if (response.success) {
                        $('#islemModali').modal('hide');
                        TabloyuDoldur();
                    } else {
                        alert("İşlem sırasında bir hata oluştu.");
                    }
                });
            }
        </script>
    }
