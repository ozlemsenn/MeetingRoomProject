@model MeetingProject.Models.Reservations
@{
    Layout = null;
}

<div class="modal-body p-0">
    <div class="container-fluid px-4 py-3">

        <div id="hataMesajiAlaniDuzenle" class="alert alert-warning d-none shadow-sm" style="border-radius: 8px; font-size: 0.9rem; padding: 10px;"></div>

        <form id="formDuzenle">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold mb-1">Toplantı Odası</label>
                    @Html.DropDownList("RoomId", (SelectList)ViewBag.Rooms, "Oda Seçiniz", new { @class = "form-select shadow-sm border-0 bg-light", @required = "required" })
                </div>
                <div class="col-md-6">
                    <label class="form-label text-muted small fw-bold mb-1">Kullanıcı (Arama Yapabilirsiniz)</label>

                    @Html.DropDownList("UserId", (SelectList)ViewBag.Users, "Kullanıcı Seçiniz", new { @class = "form-select shadow-sm border-0 bg-light select2-kullanici", @required = "required", style = "width: 100%;" })
                </div>
            </div>


            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold mb-1">Tarih</label>
                    <input type="date" name="Date" class="form-control shadow-sm border-0 bg-light" value="@(Model.Date.HasValue ? Model.Date.Value.ToString("yyyy-MM-dd") : "")" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold mb-1">Başlangıç</label>
                    <input type="time" name="StartTime" class="form-control shadow-sm border-0 bg-light" value="@(Model.StartTime.HasValue ? Model.StartTime.Value.ToString(@"hh\:mm") : "")" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label text-muted small fw-bold mb-1">Bitiş</label>
                    <input type="time" name="EndTime" class="form-control shadow-sm border-0 bg-light" value="@(Model.EndTime.HasValue ? Model.EndTime.Value.ToString(@"hh\:mm") : "")" required />
                </div>
            </div>

            <div class="row mb-2">
                <div class="mb-2">
                    <label class="form-label text-muted small fw-bold mb-1">Açıklama / Amacı</label>
                    <textarea name="Description" class="form-control shadow-sm border-0 bg-light" rows="3" style="width: 100% !important; max-width: 100% !important; resize: none;" placeholder="Örn: Bütçe değerlendirmesi..." required></textarea>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal-footer border-0 bg-white justify-content-end" style="padding: 15px 20px; border-radius: 0 0 15px 15px;">
    <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;" onclick="$('#islemModali').modal('hide');">İptal</button>
    <button type="button" class="btn btn-warning px-4 shadow-sm fw-bold text-dark" style="border-radius: 8px;" onclick="Guncelle()">Değişiklikleri Kaydet</button>
</div>

<script>
    $(document).ready(function () {
        $('.select2-kullanici').select2({
            dropdownParent: $('#islemModali'),
            placeholder: "Kullanıcı Ara...",
            allowClear: true
        });
    });
</script>