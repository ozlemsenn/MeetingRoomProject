@model MeetingProject.Models.Reservations
@{
    Layout = null;
}

<div class="modal-header border-0 pb-0">
    <h5 class="modal-title fw-bold text-danger">⚠️ Rezervasyonu İptal Et</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body text-center py-4">
    <p class="mb-0">Bu randevuyu iptal etmek istediğinize emin misiniz?</p>
    <small class="text-muted">Bu işlem geri alınamaz ve toplantı odası başkaları için uygun hale gelir.</small>

    <form id="formSil">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
    </form>
</div>

<div class="modal-footer border-0 pt-0 justify-content-center">
    <button type="button" class="btn btn-light" style="border-radius: 15px;" data-bs-dismiss="modal">Vazgeç</button>
    <button type="button" class="btn btn-danger" style="border-radius: 15px; padding: 8px 25px;" onclick="Sil()">Evet, İptal Et</button>
</div>