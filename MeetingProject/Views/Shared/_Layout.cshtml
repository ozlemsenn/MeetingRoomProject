<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <!--datatables için-->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- Menüye özel tasarım (Sayfanın head kısmına da taşıyabilirsiniz, burada da kalabilir) -->
    <style>
        .navbar-ozel {
            background: #fff;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
            padding: 12px 0;
            margin-bottom: 30px;
            border-bottom: 1px solid #ececec;
        }

        .menu-link {
            font-weight: 600;
            color: #555 !important;
            padding: 8px 18px !important;
            border-radius: 20px;
            transition: all 0.3s ease;
            margin: 0 5px;
        }

            .menu-link:hover {
                background: #f5faff;
                color: #007bff !important;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(0,123,255,.15);
            }

        .menu-aktif {
            background: #e8f4fd;
            color: #007bff !important;
            border-left: 4px solid #007bff;
            box-shadow: 0 2px 6px rgba(0,123,255,.15);
        }

        .brand-logo {
            color: #2c3e50;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            text-decoration: none;
            transition: all .25s ease;
        }
            .brand-logo:hover {
                text-decoration: none;
                transform: scale(1.05);
            }
            .brand-logo small {
                display: block;
                font-size: 14px;
                font-weight: 500;
                color: #777;
                margin-left: 28px;
                letter-spacing: .3px;
            }
    </style>

    <!-- Üst Menü Gövdesi -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-ozel">
        <div class="container">

            <!-- Sol Taraf: Logo -->
            <a class="navbar-brand brand-logo" href="/">
                <div>
                    <i class="bi bi-calendar2-check-fill"></i>
                    <span>Book</span>Room
                    <small>Toplantı Odası Rezervasyon Sistemi</small>
                </div>
            </a>

            <!-- Sağ Taraf: Linkler -->
            <div class="collapse navbar-collapse d-flex justify-content-end">
                <ul class="navbar-nav" style="flex-direction: row;">
                    <li class="nav-item">
                        <a class="nav-link menu-link" href="/Users/Index">
                            <i class="bi bi-people-fill"></i> Kullanıcılar
                        </a>    
                    </li>
                    <li class="nav-item">
                        <a class="nav-link menu-link" href="/Rooms/Index">
                            <i class="bi bi-building"></i> Odalar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link menu-link menu-aktif" href="/Reservations/Index">
                            <i class="bi bi-calendar-check"></i> Rezervasyonlar
                        </a>
                    </li>
                </ul>
            </div>

        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - My ASP.NET Application</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    <!-- DataTables calısma dosyaları-->
    <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script type="text/javascript" charset="utf8" src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
</body>
</html>
