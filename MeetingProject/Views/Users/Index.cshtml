@{
    ViewBag.Title = "Kullanıcı Yönetimi";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="container" style="margin-top: 30px;">
    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-8">
            <h2 class="text-primary fw-bold">Kullanıcı (Çalışan) Yönetimi</h2>
            <p class="text-muted">Sistemde kayıtlı kullanıcıları buradan yönetebilir ve yeni kullanıcı ekleyebilirsiniz.</p>
        </div>
        <div class="col-md-4 text-right" style="display: flex; justify-content: flex-end; align-items: center;">
            
            <a href="/Users/Create" class="btn btn-primary modal-tetikle" style="font-weight: bold; min-width: 150px;">
                + Yeni Kullanıcı
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-striped table-bordered text-center" style="background-color: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <thead class="thead-dark" style="background-color: #343a40; color: white;">
                <tr>
                    <th>Ad</th>
                    <th>Soyad</th>
                    <th>E-Posta</th>
                    <th>Departman</th>
                    <th style="width: 250px;">İşlemler</th>
                </tr>
            </thead>
            <tbody id="kullaniciListesi">
                <tr>
                    <td colspan="5" class="text-muted" style="padding: 20px;">Kullanıcılar yükleniyor, lütfen bekleyin...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="kullaniciModali" tabindex="-1" role="dialog" aria-labelledby="kullaniciModaliLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content" style="border-radius: 10px; border: none; box-shadow: 0 10px 20px rgba(0,0,0,0.2);">
            <div class="modal-header" style="background-color: #f8f9fa; border-bottom: 1px solid #dee2e6; border-radius: 10px 10px 0 0;">
                <h5 class="modal-title fw-bold text-secondary" id="kullaniciModaliLabel">Kullanıcı İşlemi</h5>
            </div>

            <div class="modal-body" id="modalinIci">
                <div class="text-center text-muted">
                    <p>İçerik yükleniyor...</p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function KullanicilariYukle() {
            $.ajax({
                url: '/Users/GetUsers',
                type: 'GET',
                success: function (data) {
                    var tabloIcerigi = '';

                    $.each(data, function (index, user) {
                        tabloIcerigi += '<tr>';
                        tabloIcerigi += '<td><span class="fw-bold">' + user.Name + '</span></td>';
                        tabloIcerigi += '<td>' + user.Surname + '</td>';
                        tabloIcerigi += '<td><a href="mailto:' + user.Email + '" class="text-info">' + user.Email + '</a></td>';
                        tabloIcerigi += '<td><span class="badge bg-secondary" style="padding: 6px 10px; color:white;">' + user.Department + '</span></td>';
                        tabloIcerigi += '<td>' +
                            '<a href="/Users/Edit/' + user.Id + '" class="btn btn-sm btn-outline-primary modal-tetikle" style="margin-right:5px;">Düzenle</a>' +
                            '<a href="/Users/Details/' + user.Id + '" class="btn btn-sm btn-outline-info modal-tetikle" style="margin-right:5px;">Detaylar</a>' +
                            '<a href="/Users/Delete/' + user.Id + '" class="btn btn-sm btn-outline-danger modal-tetikle">Sil</a>' +
                            '</td>';
                        tabloIcerigi += '</tr>';
                    });

                    if (data.length === 0) {
                        tabloIcerigi = '<tr><td colspan="5" class="text-muted" style="padding: 20px;">Sistemde henüz kayıtlı kullanıcı bulunmuyor.</td></tr>';
                    }

                    $('#kullaniciListesi').html(tabloIcerigi);
                },
                error: function () {
                    console.log("Kullanıcılar yüklenirken sunucuya ulaşılamadı.");
                }
            });
        }

        $(document).ready(function () {
            KullanicilariYukle();

            $(document).on('click', '.modal-tetikle', function (Olay) {
                Olay.preventDefault();
                var gidilecekAdres = $(this).attr('href');

                $('#modalinIci').load(gidilecekAdres, function () {
                    $('#kullaniciModali').modal('show');

                    if (gidilecekAdres.indexOf('/Users/Edit/') !== -1 ||
                        gidilecekAdres.indexOf('/Users/Delete/') !== -1 ||
                        gidilecekAdres.indexOf('/Users/Details/') !== -1) {

                        var userId = gidilecekAdres.split('/').pop();

                        $.ajax({
                            url: '/Users/GetUserData/' + userId,
                            type: 'GET',
                            success: function(kullaniciBilgisi) {

                                if(gidilecekAdres.indexOf('/Users/Edit/') !== -1) {
                                    $('#EditId').val(kullaniciBilgisi.Id);
                                    $('#EditName').val(kullaniciBilgisi.Name);
                                    $('#EditSurname').val(kullaniciBilgisi.Surname);
                                    $('#EditEmail').val(kullaniciBilgisi.Email);
                                    $('#EditDepartment').val(kullaniciBilgisi.Department);
                                }

                                else if(gidilecekAdres.indexOf('/Users/Delete/') !== -1) {
                                    $('#DeleteId').val(kullaniciBilgisi.Id);
                                    $('#DeleteFullName').text(kullaniciBilgisi.Name + ' ' + kullaniciBilgisi.Surname);
                                    $('#DeleteDepartment').text(kullaniciBilgisi.Department);
                                }

                                else if(gidilecekAdres.indexOf('/Users/Details/') !== -1) {
                                    $('#DetailsFullName').text(kullaniciBilgisi.Name + ' ' + kullaniciBilgisi.Surname);
                                    $('#DetailsEmail').text(kullaniciBilgisi.Email);
                                    $('#DetailsDepartment').text(kullaniciBilgisi.Department);
                                }
                            }
                        });
                    }
                });
            });

            $(document).on("submit", "#createForm", function (e) {
                e.preventDefault();
                $.ajax({
                    url: "/Users/Create",
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#kullaniciModali').modal('hide');
                            KullanicilariYukle();
                        } else {
                            alert("Kayıt başarısız oldu.");
                        }
                    }
                });
            });

            $(document).on("submit", "#editForm", function (e) {
                e.preventDefault();
                $.ajax({
                    url: "/Users/Edit",
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#kullaniciModali').modal('hide');
                            KullanicilariYukle();
                        } else {
                            alert("Güncelleme başarısız oldu.");
                        }
                    }
                });
            });

            $(document).on("submit", "#deleteForm", function (e) {
                e.preventDefault();
                var silinecekId = $('#DeleteId').val(); 
                $.ajax({
                    url: "/Users/Delete/" + silinecekId,
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#kullaniciModali').modal('hide');
                            KullanicilariYukle();
                        } else {
                            alert("Silme işlemi başarısız oldu.");
                        }
                    }
                });
            });

        });
    </script>
}