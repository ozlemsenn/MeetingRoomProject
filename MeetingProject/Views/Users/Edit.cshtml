@{
    ViewBag.Title = "Edit";
    Layout = null;
}

<form id="editForm">
    @Html.AntiForgeryToken()

    <input type="hidden" id="EditId" name="Id" />

    <div class="container-fluid" style="padding: 15px 25px;">

        <div class="row mb-3">
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">Ad</label>
                <input type="text" id="EditName" name="Name" class="form-control shadow-sm border-0 bg-light" required />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">Soyad</label>
                <input type="text" id="EditSurname" name="Surname" class="form-control shadow-sm border-0 bg-light" required />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">E-Posta</label>
                <input type="email" id="EditEmail" name="Email" class="form-control shadow-sm border-0 bg-light" required />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">Departman</label>
                <select id="EditDepartment" name="Department" class="form-select shadow-sm border-0 bg-light" required>
                    <option value="" disabled>Seçiniz...</option>
                    <option value="IT">IT (Bilgi İşlem)</option>
                    <option value="İnsan Kaynakları">İnsan Kaynakları</option>
                    <option value="Pazarlama">Pazarlama</option>
                    <option value="Satış">Satış</option>
                    <option value="Yönetim">Yönetim</option>
                </select>
            </div>
        </div>

    </div>

    <div class="modal-footer border-0 bg-white d-flex justify-content-end" style="padding: 15px 25px; border-radius: 0 0 10px 10px;">
        <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;" onclick="$('#kullaniciModali').modal('hide');">İptal</button>
        <button type="submit" class="btn btn-warning px-4 shadow-sm fw-bold text-dark" style="border-radius: 8px;">Kaydet</button>
    </div>
</form>