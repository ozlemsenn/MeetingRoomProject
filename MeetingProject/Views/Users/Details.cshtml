@{
    ViewBag.Title = "Details";
    Layout = null;
}

<div class="container-fluid px-2 py-3">
    <div class="card border-0 shadow-sm" style="border-radius: 15px; background-color: #f8f9fa;">
        <div class="card-body p-4 text-center">

            <div class="d-inline-flex align-items-center justify-content-center text-white mb-3 shadow" style="width: 85px; height: 85px; border-radius: 50%; background: linear-gradient(135deg, #0dcaf0 0%, #0dcaf0 100%);">
                <i class="fas fa-user-tie" style="font-size: 2.8rem;"></i>
            </div>

            <h3 id="DetailsFullName" class="fw-bold text-dark mb-1">Yükleniyor...</h3>

            <div class="mb-4 pb-4 border-bottom">
                <span id="DetailsDepartment" class="badge bg-secondary shadow-sm px-3 py-2 mt-2" style="font-size: 0.95rem; border-radius: 8px;">
                    Yükleniyor...
                </span>
            </div>

            <div class="row align-items-center justify-content-center mt-2">
                <div class="col-sm-5 text-muted fw-bold text-end">
                    <i class="fas fa-envelope text-info me-1"></i> E-Posta Adresi:
                </div>
                <div class="col-sm-7 text-dark fw-semibold text-start" style="font-size: 1.05rem;" id="DetailsEmail">
                    Yükleniyor...
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal-footer border-0 pt-0 pb-3 justify-content-center">
    <button type="button" class="btn btn-outline-secondary shadow-sm px-5" style="border-radius: 12px; font-weight: 500;" onclick="$('#kullaniciModali').modal('hide');">Kapat</button>
</div>