@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Oda Oluştur", "Create", null, new { @class = "modal-tetikle btn btn-primary" })
</p>


<div class="table-responsive">
    <table class="table table-hover table-striped table-bordered text-center" style="background-color: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
        <thead class="thead-dark" style="background-color: #343a40; color: white;">
            <tr>
                <th>Oda Adı</th>
                <th>Kapasite</th>
                <th>Projeksiyon Durumu</th>               
                <th style="width: 250px;">İşlemler</th>
            </tr>
        </thead>
        <tbody id="odaListesi">
            <tr>
                <td colspan="5" class="text-muted" style="padding: 20px;">Kullanıcılar yükleniyor, lütfen bekleyin...</td>
            </tr>
        </tbody>
    </table>
</div>

<div class="modal fade" id="odaModali" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Oda İşlemi</h5>
                <button type="button" class="close" onclick="$('#odaModali').modal('hide');" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body" id="modalinIci">

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function OdalariYukle() {
            $.ajax({
                url: '/Rooms/GetRooms',
                type: 'GET',
                success: function (data) {
                    var tabloIcerigi = '';

                    $.each(data, function (index, oda) {
                        var projeksiyonHtml = '<span class="text-muted">Belirtilmedi</span>';
                        if (oda.HasProjector === true) {
                            projeksiyonHtml = '<span class="text-success fw-bold">Var</span>';
                        } else if (oda.HasProjector === false) {
                            projeksiyonHtml = '<span class="text-danger fw-bold">Yok</span>';
                        }

                        tabloIcerigi += '<tr>';
                        tabloIcerigi += '<td>' + oda.Name + '</td>';
                        tabloIcerigi += '<td>' + oda.Capacity + '</td>';
                        tabloIcerigi += '<td>' + projeksiyonHtml + '</td>';
                        tabloIcerigi += '<td>' +
                            '<a href="/Rooms/Edit/' + oda.Id + '" class="modal-tetikle">Düzenle</a> | ' +
                            '<a href="/Rooms/Details/' + oda.Id + '" class="modal-tetikle">Detaylar</a> | ' +
                            '<a href="/Rooms/Delete/' + oda.Id + '" class="modal-tetikle">Sil</a>' +
                            '</td>';
                        tabloIcerigi += '</tr>';
                    });

                    $('#odaListesi').html(tabloIcerigi);
                },
                error: function () {
                    console.log("Odalar yüklenirken sunucuya ulaşılamadı.");
                }
            });
        }

        $(document).ready(function () {
            OdalariYukle();

            $(document).on('click', '.modal-tetikle', function (Olay) {
                Olay.preventDefault();
                var gidilecekAdres = $(this).attr('href');

                $('#modalinIci').load(gidilecekAdres, function () {
                    $('#odaModali').modal('show');

                    if (gidilecekAdres.indexOf('/Rooms/Edit/') !== -1 ||
                        gidilecekAdres.indexOf('/Rooms/Delete/') !== -1 ||
                        gidilecekAdres.indexOf('/Rooms/Details/') !== -1) {

                        var odaId = gidilecekAdres.split('/').pop();

                        $.ajax({
                            url: '/Rooms/GetRoomData/' + odaId,
                            type: 'GET',
                            success: function (odaBilgisi) {

                                if (gidilecekAdres.indexOf('/Rooms/Edit/') !== -1) {
                                    $('#EditId').val(odaBilgisi.Id);
                                    $('#EditName').val(odaBilgisi.Name);
                                    $('#EditCapacity').val(odaBilgisi.Capacity);

                                    if (odaBilgisi.HasProjector === true) $('#EditHasProjector').val("true");
                                    else if (odaBilgisi.HasProjector === false) $('#EditHasProjector').val("false");
                                    else $('#EditHasProjector').val("");
                                }

                                else if (gidilecekAdres.indexOf('/Rooms/Delete/') !== -1) {
                                    $('#DeleteId').val(odaBilgisi.Id);
                                    $('#DeleteName').text(odaBilgisi.Name);
                                    $('#DeleteCapacity').text(odaBilgisi.Capacity + ' Kişilik');

                                    if (odaBilgisi.HasProjector === true) $('#DeleteProjector').html('<span class="text-success fw-bold">Var</span>');
                                    else if (odaBilgisi.HasProjector === false) $('#DeleteProjector').html('<span class="text-danger fw-bold">Yok</span>');
                                    else $('#DeleteProjector').html('<span class="text-muted">Belirtilmedi</span>');
                                }

                                else if (gidilecekAdres.indexOf('/Rooms/Details/') !== -1) {
                                    $('#DetailsName').text(odaBilgisi.Name);
                                    $('#DetailsCapacity').text(odaBilgisi.Capacity + ' Kişilik');

                                    if (odaBilgisi.HasProjector === true) $('#DetailsProjector').html('<span class="text-success fw-bold">Var</span>');
                                    else if (odaBilgisi.HasProjector === false) $('#DetailsProjector').html('<span class="text-danger fw-bold">Yok</span>');
                                    else $('#DetailsProjector').html('<span class="text-muted">Belirtilmedi</span>');
                                }
                            }
                        });
                    }
                });
            });

            $(document).on("submit", "#createForm", function (e) {
                e.preventDefault();
                $.ajax({
                    url: "/Rooms/Create",
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#odaModali').modal('hide');
                            OdalariYukle();
                        } else {
                            alert("Kayıt başarısız oldu.");
                        }
                    }
                });
            });

            $(document).on("submit", "#editForm", function (e) {
                e.preventDefault();
                $.ajax({
                    url: "/Rooms/Edit",
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#odaModali').modal('hide');
                            OdalariYukle();
                        } else {
                            alert("Güncelleme başarısız oldu.");
                        }
                    }
                });
            });

            $(document).on("submit", "#deleteForm", function (e) {
                e.preventDefault();
                var silinecekId = $('#DeleteId').val(); 
                $.ajax({
                    url: "/Rooms/Delete/" + silinecekId,
                    type: "POST",
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            $('#odaModali').modal('hide');
                            OdalariYukle();
                        } else {
                            alert("Silme işlemi başarısız oldu.");
                        }
                    }
                });
            });

        });
    </script>
}