@{
    ViewBag.Title = "Oda Yönetimi";
}

<div class="container" style="margin-top: 30px;">
    <div class="row" style="margin-bottom: 20px;">
        <div class="col-md-8">
            <h2 class="text-primary fw-bold">Oda Yönetimi</h2>
            <p class="text-muted">Sistemde kayıtlı odaları buradan yönetebilir ve yeni oda ekleyebilirsiniz.</p>
        </div>
        <div class="col-md-4 text-right" style="display: flex; justify-content: flex-end; align-items: center;">

            <a href="/Rooms/Create" class="btn btn-primary modal-tetikle" style="font-weight: bold; min-width: 150px;">
                + Yeni Oda
            </a>
        </div>
    </div>
    <div class="table-responsive" style="overflow-x: auto">
        <table id="odaTablosu" class="table table-hover table-striped table-bordered text-center w-100" style="width: 100%; background-color: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
            <thead class="thead-dark" style="background-color: #343a40; color: white;">
                <tr>
                    <th class="text-center align-middle" style="width: 30%;">Oda Adı</th>

                    <th class="text-center align-middle" style="width: 20%;">Kapasite</th>

                    <th class="text-center align-middle" style="width: 25%;">Projeksiyon Durumu</th>

                    <th class="text-center align-middle" style="width: 25%; min-width: 130px;">İşlemler</th>
                </tr>
            </thead>
            <tbody id="odaListesi">
                <tr>
                    <td colspan="5" class="text-muted" style="padding: 20px;">Kullanıcılar yükleniyor, lütfen bekleyin...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="modal fade" id="odaModali" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Oda İşlemi</h5>
                    <button type="button" class="close" onclick="$('#odaModali').modal('hide');" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body" id="modalinIci">

                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
            function OdalariYukle() {
                $.ajax({
                    url: '/Rooms/GetRooms',
                    type: 'GET',
                    success: function (data) {
                        var tabloIcerigi = '';

                        $.each(data, function (index, oda) {
                            var projeksiyonHtml = '<span class="text-muted">Belirtilmedi</span>';
                            if (oda.HasProjector === true) {
                                projeksiyonHtml = '<span class="text-success fw-bold">Var</span>';
                            } else if (oda.HasProjector === false) {
                                projeksiyonHtml = '<span class="text-danger fw-bold">Yok</span>';
                            }

                            tabloIcerigi += '<tr>';
                            tabloIcerigi += '<td class="align-middle" style="text-transform: capitalize;">' + oda.Name + '</td>';
                            tabloIcerigi += '<td class="align-middle">' + oda.Capacity + '</td>';
                            tabloIcerigi += '<td class="align-middle">' + projeksiyonHtml + '</td>';

                            tabloIcerigi += '<td class="align-middle text-center text-nowrap">' +
                                '<div class="d-flex justify-content-center align-items-center flex-nowrap" style="gap: 5px;">' +

                                '<a href="/Rooms/Details/' + oda.Id + '" class="btn btn-sm text-secondary border-0 shadow-none modal-tetikle p-1" title="Detaylar">' +
                                '<i class="fas fa-search" style="font-size: 1.1rem;"></i>' +
                                '</a>' +

                                '<a href="/Rooms/Edit/' + oda.Id + '" class="btn btn-sm text-secondary border-0 shadow-none modal-tetikle p-1" title="Düzenle">' +
                                '<i class="fas fa-edit" style="font-size: 1.1rem;"></i>' +
                                '</a>' +

                                '<a href="/Rooms/Delete/' + oda.Id + '" class="btn btn-sm text-secondary border-0 shadow-none modal-tetikle p-1" title="Sil">' +
                                '<i class="fas fa-trash-alt" style="font-size: 1.1rem;"></i>' +
                                '</a>' +

                                '</div>' +
                                '</td>';
                            tabloIcerigi += '</tr>';
                        });

                        $('#odaListesi').html(tabloIcerigi);
                        if ($.fn.DataTable.isDataTable('#odaTablosu')) {
                            $('#odaTablosu').DataTable().destroy();
                        }

                        $('#odaListesi').html(tabloIcerigi);

                        $('#odaTablosu').DataTable({
                            language: {
                                url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json"
                            },
                            "autowidth": false,
                            "columnDefs": [
                                {"width": "140px", "targets": -1}
                            ]
                        });
                    },
                    error: function () {
                        console.log("Odalar yüklenirken sunucuya ulaşılamadı.");
                    }
                });
            }

            $(document).ready(function () {
                OdalariYukle();

                $(document).on('click', '.modal-tetikle', function (Olay) {
                    Olay.preventDefault();
                    var gidilecekAdres = $(this).attr('href');

                    $('#modalinIci').load(gidilecekAdres, function () {
                        $('#odaModali').modal('show');

                        if (gidilecekAdres.indexOf('/Rooms/Edit/') !== -1 ||
                            gidilecekAdres.indexOf('/Rooms/Delete/') !== -1 ||
                            gidilecekAdres.indexOf('/Rooms/Details/') !== -1) {

                            var odaId = gidilecekAdres.split('/').pop();

                            $.ajax({
                                url: '/Rooms/GetRoomData/' + odaId,
                                type: 'GET',
                                success: function (odaBilgisi) {

                                    if (gidilecekAdres.indexOf('/Rooms/Edit/') !== -1) {
                                        $('#EditId').val(odaBilgisi.Id);
                                        $('#EditName').val(odaBilgisi.Name);
                                        $('#EditCapacity').val(odaBilgisi.Capacity);

                                        if (odaBilgisi.HasProjector === true) $('#EditHasProjector').val("true");
                                        else if (odaBilgisi.HasProjector === false) $('#EditHasProjector').val("false");
                                        else $('#EditHasProjector').val("");
                                    }

                                    else if (gidilecekAdres.indexOf('/Rooms/Delete/') !== -1) {
                                        $('#DeleteId').val(odaBilgisi.Id);
                                        $('#DeleteName').text(odaBilgisi.Name);
                                        $('#DeleteCapacity').text(odaBilgisi.Capacity + ' Kişilik');

                                        if (odaBilgisi.HasProjector === true) $('#DeleteProjector').html('<span class="text-success fw-bold">Var</span>');
                                        else if (odaBilgisi.HasProjector === false) $('#DeleteProjector').html('<span class="text-danger fw-bold">Yok</span>');
                                        else $('#DeleteProjector').html('<span class="text-muted">Belirtilmedi</span>');
                                    }

                                    else if (gidilecekAdres.indexOf('/Rooms/Details/') !== -1) {
                                        $('#DetailsName').text(odaBilgisi.Name);
                                        $('#DetailsCapacity').text(odaBilgisi.Capacity + ' Kişilik');

                                        if (odaBilgisi.HasProjector === true) $('#DetailsProjector').html('<span class="text-success fw-bold">Var</span>');
                                        else if (odaBilgisi.HasProjector === false) $('#DetailsProjector').html('<span class="text-danger fw-bold">Yok</span>');
                                        else $('#DetailsProjector').html('<span class="text-muted">Belirtilmedi</span>');
                                    }
                                }
                            });
                        }
                    });
                });

                $(document).on("submit", "#createForm", function (e) {
                    e.preventDefault();
                    $.ajax({
                        url: "/Rooms/Create",
                        type: "POST",
                        data: $(this).serialize(),
                        success: function (result) {
                            if (result.success) {
                                $('#odaModali').modal('hide');
                                OdalariYukle();
                            } else {
                                alert("Kayıt başarısız oldu.");
                            }
                        }
                    });
                });

                $(document).on("submit", "#editForm", function (e) {
                    e.preventDefault();
                    $.ajax({
                        url: "/Rooms/Edit",
                        type: "POST",
                        data: $(this).serialize(),
                        success: function (result) {
                            if (result.success) {
                                $('#odaModali').modal('hide');
                                OdalariYukle();
                            } else {
                                alert("Güncelleme başarısız oldu.");
                            }
                        }
                    });
                });

                $(document).on("submit", "#deleteForm", function (e) {
                    e.preventDefault();
                    var silinecekId = $('#DeleteId').val();
                    $.ajax({
                        url: "/Rooms/Delete/" + silinecekId,
                        type: "POST",
                        data: $(this).serialize(),
                        success: function (result) {
                            if (result.success) {
                                $('#odaModali').modal('hide');
                                OdalariYukle();
                            } else {
                                alert("Silme işlemi başarısız oldu.");
                            }
                        }
                    });
                });

            });
        </script>
    }
