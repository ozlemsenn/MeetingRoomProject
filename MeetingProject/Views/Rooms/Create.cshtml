@{
    ViewBag.Title = "Create";
    Layout = null;
}

<form id="createForm">
    
    @Html.AntiForgeryToken()

    <div class="text-center" style="padding: 10px;">

        <div class="form-group" style="margin-bottom: 15px;">
            <label class="control-label fw-bold" style="margin-bottom: 5px;">Oda Adı</label>
            <div>
                <input type="text" id="CreateName" name="Name" class="form-control text-center" style="margin: 0 auto; max-width: 300px;" placeholder="Örn: Toplantı Odası 1" required />
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 15px;">
            <label class="control-label fw-bold" style="margin-bottom: 5px;">Kapasite (Kişi)</label>
            <div>
                <input type="number" id="CreateCapacity" name="Capacity" class="form-control text-center" style="margin: 0 auto; max-width: 300px;" placeholder="Örn: 10" required />
            </div>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label class="control-label fw-bold" style="margin-bottom: 5px;">Projeksiyon Cihazı Var Mı?</label>
            <div>
                
                <select id="CreateHasProjector" name="HasProjector" class="form-control text-center" style="margin: 0 auto; max-width: 300px;" required>
                    <option value="" selected>Seçiniz...</option>
                    <option value="true">Var</option>
                    <option value="false">Yok</option>
                </select>
            </div>
        </div>
    </div>

    <div class="modal-footer" style="padding-bottom: 0; border-top: 1px solid #dee2e6; margin-top: 15px; display: flex; justify-content: center; gap: 10px;">
        <button type="button" class="btn btn-secondary" style="min-width: 100px;" onclick="$('#odaModali').modal('hide');">Kapat</button>
        <button type="submit" class="btn btn-success" style="min-width: 100px;">Kaydet</button>
    </div>
</form>