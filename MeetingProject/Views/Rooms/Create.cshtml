@{
    ViewBag.Title = "Create";
    Layout = null;
}

<form id="createForm">
    @Html.AntiForgeryToken()

    <div class="container-fluid" style="padding: 20px;">

        <div class="row mb-4">
            <div class="col-md-7">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">Oda Adı</label>
                <input type="text" id="CreateName" name="Name" class="form-control shadow-sm border-0 bg-light" placeholder="Örn: Toplantı Odası 1" required />
            </div>
            <div class="col-md-5">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">Kapasite</label>
                <input type="number" id="CreateCapacity" name="Capacity" class="form-control shadow-sm border-0 bg-light" placeholder="Örn: 12" required min="1" />
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-12">
                <label class="form-label fw-bold text-muted" style="font-size: 0.9rem;">Projeksiyon Durumu</label>
                <select id="CreateHasProjector" name="HasProjector" class="form-select shadow-sm border-0 bg-light" required>
                    <option value="" selected disabled>Seçiniz...</option>
                    <option value="true">Var (Mevcut)</option>
                    <option value="false">Yok</option>
                </select>
            </div>
        </div>

    </div>

    <div class="modal-footer border-0 bg-white d-flex justify-content-end" style="padding: 15px 20px; border-radius: 0 0 10px 10px;">

        <button type="button" class="btn btn-outline-secondary px-4 shadow-sm" style="border-radius: 8px;" onclick="$('#odaModali').modal('hide');">İptal</button>

        <button type="submit" class="btn px-4 shadow-sm text-white" style="background-color: #343a40; border-color: #343a40; border-radius: 8px;">Kaydet</button>

    </div>
</form>